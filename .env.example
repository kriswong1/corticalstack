# CorticalStack environment configuration.
# Copy to .env and fill in the values you want to use.

# Path to your Obsidian vault. CorticalStack will create this folder if it
# doesn't exist and write notes into it. Use an absolute path to point at
# an existing vault, e.g. C:\Users\you\Documents\Obsidian\MyVault.
VAULT_PATH=vault

# Port for the local dashboard (default 8000).
PORT=8000

# Claude CLI model override. Leave blank for the CLI default.
# Example: claude-sonnet-4-6
CLAUDE_MODEL=

# Deepgram API key, required for audio ingest (mp3/wav/m4a/ogg/flac/webm).
# Sign up at https://deepgram.com and paste a project API key here.
DEEPGRAM_API_KEY=
